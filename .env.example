# Base URL của MAIN_SERVER (không có dấu / ở cuối)
# Ví dụ: https://api.example.com
VITE_MAIN_SERVER=https://cloud.goads.com.vn

# Gọi GET /api/devices trên MAIN_SERVER (yêu cầu requirement.md)
# Đặt false nếu backend chưa có endpoint — app sẽ dùng thiết bị từ login + quét LAN
VITE_USE_DEVICES_API=false

# Quét LAN tự động khi vào dashboard (một lần mỗi phiên tab). Đặt false để chỉ quét tay.
# VITE_AUTO_LAN_SCAN=false

# Timeout mỗi IP khi gọi /api/system/status (ms), mặc định 3000 — tăng nếu mạng chậm (tránh tưởng “sót” IP)
# VITE_LAN_PROBE_TIMEOUT_MS=4000

# Khi WebRTC không suy ra được IP LAN (VPN, trình duyệt chặn…), dùng subnet cố định (có thể nhiều, phân tách phẩy)
# VITE_AUTO_SCAN_SUBNETS=192.168.1
# VITE_DEFAULT_LAN_SUBNET=192.168.1
